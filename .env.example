# Copy to `.env` (or source from `.envrc`) and fill in real values.
# Never commit a populated `.env` — `.gitignore` blocks `.env*` except this template.
# Real secret values must be live-issued from each provider, never reused.

CONTEXT7_API_KEY=replace-me-with-context7-api-key  # trufflehog:ignore
FIRECRAWL_LOCAL_API_URL=http://localhost:3002       # trufflehog:ignore
GITHUB_TOKEN=replace-me-with-github-pat             # trufflehog:ignore
